# --- shared -----------------------------------------------------------------
APP_URL=http://localhost:3000

# Supabase (EU project)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Next.js public counterparts (same values as above, exposed to the browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- rate limiting (apps/web, widget routes — Phase 2) --------------------------
# Upstash Redis REST — create the database in an EU region (e.g. Frankfurt)!
# Missing values disable rate limiting (fail-open, single warning in the logs).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- apps/worker only ---------------------------------------------------------
# Direct/session-mode connection — pg-boss does NOT work through the transaction pooler
DATABASE_URL_SESSION=

# --- AI (from Phase 4) --------------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=                # embeddings only

# --- crypto -------------------------------------------------------------------
# 32 bytes, base64 — encrypts channels.config / integrations.config credentials
# generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MASTER_ENCRYPTION_KEY=

# --- email via Resend (from Phase 3) -------------------------------------------
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=         # Svix signing secret (shown only once when creating the webhook)
INBOUND_EMAIL_DOMAIN=          # e.g. in.zendori.ai — NEVER the root domain
RESEND_API_BASE=               # default https://api.resend.com — override for local tests against a stub server
RESEND_FROM=                   # verified sender for outbound mail, e.g. "Zendori Support <support@zendori.de>"

# --- WhatsApp (from Phase 7) ----------------------------------------------------
# 7a — Twilio: per-org AccountSid/AuthToken + sender number are stored ENCRYPTED
#   in channels.config (via the settings UI), NOT here. Only the stub override
#   below is an env var:
TWILIO_API_BASE=               # default https://api.twilio.com — override for local tests against a stub server
# 7b — Meta (Embedded Signup / Tech Provider) — platform-level only; per-WABA
#   access_token + phone_number_id are stored encrypted in channels.config:
WHATSAPP_APP_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_CONFIG_ID=

# HubSpot tokens: encrypted per org in integrations.config, NOT here

# --- Voice via xAI + Twilio SIP (Phase 9) ---------------------------------------
XAI_API_KEY=                   # worker only — absent disables the voice dispatch
XAI_API_BASE=                  # default https://api.x.ai — override for local stub tests
VOICE_MAX_CONCURRENT_CALLS=    # worker, optional (default 10)
# Number provisioning (operator CLI apps/worker/scripts/provision-voice-number.ts):
TWILIO_ACCOUNT_SID=            # shared with WhatsApp 7a if same account
TWILIO_AUTH_TOKEN=
# One approved DE regulatory bundle (BU…) per number type you provision — local and
# mobile have different regulatory requirements, so each needs its own bundle. The
# CLI's required --type flag picks the match. Set only the types you actually use.
TWILIO_BUNDLE_SID_LOCAL=       # bundle for DE local/geographic numbers
TWILIO_BUNDLE_SID_MOBILE=      # bundle for DE mobile numbers
# (--type national → 032 numbers also exists; add TWILIO_BUNDLE_SID_NATIONAL then)
TWILIO_VOICE_TRUNK_SID=        # elastic SIP trunk (TK…) with origination → sip.voice.x.ai
# Per-number xAI dispatch signing secret: encrypted in channels.config, NOT here

# --- tests (optional, for RLS tests against a local supabase instance) ---------
# Set these to run the RLS integration tests (pnpm test); they are skipped otherwise.
ZENDORI_TEST_SUPABASE_URL=
ZENDORI_TEST_SUPABASE_ANON_KEY=
ZENDORI_TEST_SUPABASE_SERVICE_ROLE_KEY=
