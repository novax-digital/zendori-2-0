# Zendori worker — runtime env for the Hetzner container.
# Copy to `.env` NEXT TO docker-compose.yml on the VPS and fill in real values.
# Never commit the real .env. docker-compose.yml reads this file (env_file: .env).
# See docs/deploy-worker.md for the full deploy runbook.

# --- image reference (used by docker-compose.yml) --------------------------------
GHCR_OWNER=novax-digital
# Pin to an immutable per-commit tag (the GitHub SHA), NOT :latest. Read the SHA
# from the "Worker Image" GitHub Action run you want to deploy. `:main` also works
# but is mutable — pinning the SHA is the CLAUDE.md §12 rule.
WORKER_IMAGE_TAG=

# --- Supabase / pg-boss (REQUIRED) -----------------------------------------------
# pg-boss needs a SESSION-mode connection (direct port 5432 or the session pooler),
# NEVER the transaction pooler (CLAUDE.md §3).
DATABASE_URL_SESSION=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Needed to decrypt per-channel/integration secrets (WhatsApp/HubSpot/voice).
MASTER_ENCRYPTION_KEY=

# --- AI (REQUIRED) ----------------------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=                # embeddings only
# ANTHROPIC_API_BASE=          # override only for local stubs; leave empty in prod
# OPENAI_BASE_URL=

# --- E-mail via Resend (REQUIRED for outbound replies) ---------------------------
RESEND_API_KEY=
RESEND_FROM=                   # verified sender, e.g. "Support <support@zendori.de>"
INBOUND_EMAIL_DOMAIN=          # e.g. in.zendori.de
# RESEND_API_BASE=             # override only for local stubs

# --- Voice via xAI (OPTIONAL — absent disables voice dispatch entirely) ----------
XAI_API_KEY=
# XAI_API_BASE=                # default https://api.x.ai
VOICE_MAX_CONCURRENT_CALLS=30

# --- misc -------------------------------------------------------------------------
LOG_LEVEL=warn                 # 'info' also prints the "worker started" line
# HEARTBEAT_FILE=/tmp/zendori-worker-heartbeat   # default is fine

# NOTE: Twilio/HubSpot per-customer credentials are stored encrypted in the DB
# (channels.config / integrations.config), NOT here. TWILIO_ACCOUNT_SID/AUTH_TOKEN
# are only needed by the one-off number-provisioning CLI, not the running worker.
